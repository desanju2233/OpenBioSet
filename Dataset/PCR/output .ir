main:
	a1[0] = dispense(pcr_mixture)
	heat(a1[0]) @ 95.0CELSIUS @ 5.0SECOND
bsbbr_2_h:
	PHI REPEAT_201 = {REPEAT_200,REPEAT_202}
	PHI a2 = {a1,a2}
	if REPEAT_201[0] > 0	|	true: jump bsbbr_3_t	|	false: jump bsbbr_4_f
bsbbr_3_t:
	heat(a2[0]) @ 53.0CELSIUS @ 15.0SECOND
	heat(a2[0]) @ 72.0CELSIUS @ 10.0SECOND
	REPEAT_202[0] = REPEAT_201[0] - 1
bsbbr_4_f:
	x1[0] = detect(fluorescence, a2[0]) @ 180.0SECOND
	dispose(a2[0])
	NOP
